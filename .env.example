PORT=7070
MONGODB_URI=mongodb://localhost:27017/elippser-booking
# Mismo valor que JWT_SECRET en pms-core/api (tokens del login del PMS)
STAFF_JWT_SECRET=
# Alternativa: si definís JWT_SECRET aquí, se usa si STAFF_JWT_SECRET está vacío
# JWT_SECRET=
GUEST_JWT_SECRET=
# pms-core API (mismo host/puerto que el login). Si no copiás el JWT_SECRET aquí,
# authenticateStaff valida el Bearer contra GET /user/profile de esta URL.
CORE_API_URL=http://localhost:3030
GUEST_AUTH_URL=http://localhost:5050
ROOMS_API_URL=http://localhost:4040
NODE_ENV=development
